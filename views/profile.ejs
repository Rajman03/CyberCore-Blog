<div class="container fade-in">
    <div class="dashboard-grid">
        <!-- Sidebar / Profile Summary -->
        <aside>
            <div class="glass-card" style="text-align: center; padding: 2rem 1.5rem;">
                <div class="profile-avatar" id="avatar-initials"><%= user.username.substring(0, 2).toUpperCase() %></div>
                <h2 style="margin-bottom: 0.5rem;"><%= user.username %></h2>
                <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;"><%= user.email %></p>
                <div id="role-badge-container">
                    <span class="badge badge-<%= user.role %>"><%= user.role.toUpperCase() %></span>
                </div>
                <hr style="border: 0; border-top: 1px solid var(--glass-border); margin: 2rem 0;">
                <div style="display: flex; flex-direction: column; gap: 1rem; text-align: left;">
                    <div class="stat-card">
                        <span style="font-size: 0.8rem; color: var(--text-muted);">Status Konta</span>
                        <div style="color: var(--accent); font-weight: 700; font-size: 1rem;">Aktywne</div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main>
            <header style="margin-bottom: 2rem;">
                <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">👤 Twój Profil</h1>
                <p style="color: var(--text-muted);">Zarządzaj swoimi danymi i ustawieniami bezpieczeństwa.</p>
            </header>

            <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
                <!-- Personal Info -->
                <div class="glass-card">
                    <h3 style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                        <span>📝</span> Informacje Podstawowe
                    </h3>
                    <form id="profile-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div class="form-group">
                            <label>Nazwa Użytkownika</label>
                            <input type="text" id="username" value="<%= user.username %>" required>
                        </div>
                        <div class="form-group">
                            <label>Adres Email</label>
                            <input type="email" id="email" value="<%= user.email %>" required>
                        </div>
                        <div style="grid-column: 1 / -1;">
                            <button type="submit" style="width: auto; padding: 12px 30px;">Zaktualizuj Profil</button>
                        </div>
                    </form>
                    <div id="profile-msg" style="margin-top: 1rem; font-size: 0.9rem;"></div>
                </div>

                <!-- Security / Password -->
                <div class="glass-card">
                    <h3 style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px; color: var(--danger);">
                        <span>🔒</span> Bezpieczeństwo
                    </h3>
                    <form id="password-form" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                        <div class="form-group">
                            <label>Obecne Hasło</label>
                            <input type="password" id="old-password" required placeholder="••••••••">
                        </div>
                        <div class="form-group">
                            <label>Nowe Hasło</label>
                            <input type="password" id="new-password" required placeholder="Min. 8 znaków">
                        </div>
                        <div style="grid-column: 1 / -1;">
                            <button type="submit" class="secondary" style="width: auto; padding: 12px 30px; border-color: rgba(244, 63, 94, 0.4); color: var(--danger);">Zmień Hasło</button>
                        </div>
                    </form>
                    <div id="password-msg" style="margin-top: 1rem; font-size: 0.9rem;"></div>
                </div>
            </div>
        </main>
    </div>
</div>

<script>
    // Personal Info Update
    document.getElementById('profile-form').onsubmit = async (e) => {
        e.preventDefault();
        const msg = document.getElementById('profile-msg');
        try {
            await API.updateProfile({
                username: document.getElementById('username').value,
                email: document.getElementById('email').value
            });
            msg.style.color = 'var(--accent)';
            msg.innerText = '✅ Profil zaktualizowany pomyślnie!';
            setTimeout(() => location.reload(), 1000);
        } catch (err) {
            msg.style.color = 'var(--danger)';
            msg.innerText = '❌ ' + err.message;
        }
    };

    // Password Update
    document.getElementById('password-form').onsubmit = async (e) => {
        e.preventDefault();
        const msg = document.getElementById('password-msg');
        try {
            await API.changePassword(
                document.getElementById('old-password').value,
                document.getElementById('new-password').value
            );
            msg.style.color = 'var(--accent)';
            msg.innerText = '✅ Hasło zostało zmienione!';
            e.target.reset();
        } catch (err) {
            msg.style.color = 'var(--danger)';
            msg.innerText = '❌ ' + err.message;
        }
    };
</script>
