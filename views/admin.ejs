<div class="container fade-in" style="max-width: 1300px;">
    <div class="dashboard-grid">
        <aside style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div class="glass-card" style="padding: 1.5rem;">
                <h4 style="color: var(--text-muted); margin-bottom: 1rem; font-size: 0.8rem; text-transform: uppercase;">Status Systemu</h4>
                <div style="display: flex; align-items: center; gap: 10px; color: var(--accent); font-weight: 700;">
                    <span style="width: 8px; height: 8px; background: var(--accent); border-radius: 50%; box-shadow: 0 0 10px var(--accent);"></span>
                    Silnik SQL Online
                </div>
            </div>

            <div class="stat-card">
                <span style="font-size: 0.8rem; color: var(--text-muted);">Łącznie Postów</span>
                <div class="stat-val" id="stat-posts">0</div>
            </div>

            <div class="stat-card">
                <span style="font-size: 0.8rem; color: var(--text-muted);">Użytkownicy</span>
                <div class="stat-val" id="stat-users">0</div>
            </div>

            <div class="glass-card" style="padding: 1.5rem;">
                <h4 style="color: var(--text-muted); margin-bottom: 1rem; font-size: 0.8rem; text-transform: uppercase;">Twoja Sesja</h4>
                <p id="admin-name" style="font-weight: 700; margin-bottom: 0.5rem;"><%= user.username %></p>
                <span class="badge badge-admin">Administrator</span>
            </div>
        </aside>

        <main style="display: flex; flex-direction: column; gap: 2rem;">
            <div class="glass-card">
                <h2 style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                    <span>🛡️</span> Centrum Dowodzenia
                </h2>
                <form id="add-post-form">
                    <div class="form-group">
                        <label>Tytuł Posta</label>
                        <input type="text" id="post-title" required placeholder="O czym dziś napiszemy?">
                    </div>
                    <div class="form-group">
                        <label>Treść</label>
                        <textarea id="post-content" rows="6" required placeholder="Wpisz treść posta..."></textarea>
                    </div>
                    <button type="submit" style="width: 100%;">Opublikuj w Bazie Danych</button>
                </form>
                <div id="status-msg" style="margin-top: 1rem; font-size: 0.9rem;"></div>
            </div>

            <div class="glass-card">
                <h2 style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                    <span>📋</span> Zarządzanie Postami
                </h2>
                <div id="admin-posts-list" style="display: flex; flex-direction: column; gap: 1rem;">
                </div>
            </div>

            <div class="glass-card">
                <h2 style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 10px;">
                    <span>👥</span> Uprawnienia Użytkowników
                </h2>
                <div id="users-list" style="display: flex; flex-direction: column; gap: 1rem;">
                </div>
            </div>
        </main>
    </div>
</div>

<script src="js/admin.js"></script>
